  nodes:
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u041F\u0440\u0438\u0432\u0435\u0442. \u041E \u0447\u0451\u043C \u0445\u043E\u0447\u0435\u0448\u044C
      \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C?"
    choices:
    - choiceText: "\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430."
      nextNodeIndex: 1
    - choiceText: "\u0425\u043E\u0447\u0443 \u0443\u0437\u043D\u0430\u0435\u0442\u044C
        \u043A\u043E\u0435 \u0447\u0442\u043E?"
      nextNodeIndex: 5
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u0423 \u043C\u0435\u043D\u044F \u043A\u0430\u043A \u0440\u0430\u0437
      \u0435\u0441\u0442\u044C \u0434\u0435\u043B\u043E \u0434\u043B\u044F \u0442\u0435\u0431\u044F."
    choices:
    - choiceText: "\u0417\u0434\u043E\u0440\u043E\u0432\u043E"
      nextNodeIndex: 2
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u042F \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u043E\u0434\u0438\u043D
      \u0432\u0430\u0436\u043D\u044B\u0439 \u043F\u0440\u0435\u0434\u043C\u0435\u0442"
    choices:
    - choiceText: ...
      nextNodeIndex: 3
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u043F\u0440\u0438\u043D\u0435\u0441\u0438 \u0435\u0433\u043E  \u043C\u043D\u0435."
    choices:
    - choiceText: ...
      nextNodeIndex: 4
    isEnding: 0
    givesQuest: 1
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u0411\u0443\u0434\u0443 \u0436\u0434\u0430\u0442\u044C."
    choices:
    - choiceText: "\u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C"
      nextNodeIndex: -1
    isEnding: 1
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u0425\u043E\u0440\u043E\u0448\u043E. \u0427\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
      \u0442\u0435\u0431\u044F \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u0435\u0442?"
    choices:
    - choiceText: "\u0427\u0442\u043E \u044D\u0442\u043E \u0437\u0430 \u043C\u0435\u0441\u0442\u043E?"
      nextNodeIndex: 7
    - choiceText: "\u041A\u0442\u043E \u0442\u044B?"
      nextNodeIndex: 8
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u042D\u0442\u043E \u0442\u0435\u0441\u0442\u043E\u0432\u044B\u0439 \u043C\u0438\u0440"
    choices:
    - choiceText: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E."
      nextNodeIndex: 11
    - choiceText: "\u0415\u0449\u0451 \u0432\u043E\u043F\u0440\u043E\u0441"
      nextNodeIndex: 6
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u042F \u0442\u0435\u0441\u0442\u043E\u0432\u044B\u0439 \u041D\u041F\u0421.
      \u0414\u0430\u044E \u0437\u0430\u0434\u0430\u043D\u0438\u044F \u0438 \u043E\u0442\u0432\u0435\u0447\u0430\u044E
      \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441\u044B."
    choices:
    - choiceText: "\u041E\u0442\u043A\u0443\u0434\u0430 \u0442\u044B \u0437\u043D\u0430\u0435\u0448\u044C
        \u044D\u0442\u043E?"
      nextNodeIndex: 9
    - choiceText: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E"
      nextNodeIndex: 11
    - choiceText: "\u0415\u0449\u0451 \u0432\u043E\u043F\u0440\u043E\u0441"
      nextNodeIndex: 6
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430"
    text: "\u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0441\u043A\u0430\u0437\u0430\u043B
      \u043C\u043D\u0435"
    choices:
    - choiceText: "\u041A\u0422\u041E?!"
      nextNodeIndex: 10
    isEnding: 0
    givesQuest: 0
  - speakerName: "\u0421\u043C\u043E\u0442\u0440\u0438\u0442\u0435\u043B\u044C"
    text: "\u042D\u0442\u043E \u0441\u0442\u0430\u0440\u044B\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441.
